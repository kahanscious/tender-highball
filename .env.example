# your public domain (e.g. https://search.example.com)
SEARXNG_BASE_URL=https://search.example.com

# generated by setup.sh — leave blank, do not fill in manually
SEARXNG_SECRET_KEY=

# from Cloudflare Zero Trust dashboard → Tunnels → your tunnel → Token
CLOUDFLARE_TUNNEL_TOKEN=

# UA string your client sends; must match the Cloudflare WAF rule you create
APP_USER_AGENT=MyApp
