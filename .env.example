# your public domain (e.g. https://search.example.com)
SEARXNG_BASE_URL=https://search.example.com

# generated by setup.sh — leave blank, do not fill in manually
SEARXNG_SECRET_KEY=

# from Cloudflare Zero Trust dashboard → Tunnels → your tunnel → Token
CLOUDFLARE_TUNNEL_TOKEN=

# Informational only — not injected into containers.
# This is the User-Agent string your client must send, and what your Cloudflare WAF rule should match.
APP_USER_AGENT=YourAppName
